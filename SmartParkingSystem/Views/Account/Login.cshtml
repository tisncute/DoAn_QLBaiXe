@{
    ViewData["Title"] = "Đăng Nhập Hệ Thống";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-primary bg-dark text-white">
            <div class="card-header bg-primary text-center py-3">
                <h3 class="mb-0 fw-bold">🔒 ĐĂNG NHẬP</h3>
            </div>
            <div class="card-body p-4">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger fw-bold text-center">
                        ❌ @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary text-white border-0">👤</span>
                            <input type="text" name="username" class="form-control" placeholder="Click vào để nhập" required
                                   oninvalid="this.setCustomValidity('Vui lòng nhập tên đăng nhập')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary text-white border-0">🔑</span>
                            <input type="password" name="password" class="form-control" placeholder="Click vào để nhập" required
                                   oninvalid="this.setCustomValidity('Vui lòng nhập mật khẩu')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm" style="color: black !important;">
                            ĐĂNG NHẬP
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>